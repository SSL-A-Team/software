"""Controls analysis republisher node.

Subscribes to a single robot's ``ateam_radio_msgs/ExtendedTelemetry`` and
republishes flat, PlotJuggler-friendly ``ControlsAnalysis`` messages. Works for
both live streaming and ROS-bag playback (run this node while playing a bag).

Parameters:
  * ``robot_id`` (int, default 0): robot whose telemetry to analyze.
  * ``input_topic`` (str, default ''): override input topic; when empty,
    ``/robot_feedback/extended/robot{robot_id}`` is used.
  * ``output_topic`` (str, default ''): override output topic; when empty,
    ``/controls_analysis/robot{robot_id}`` is used.
  * ``reliability`` (str, default 'reliable'): 'reliable' or 'best_effort'
    for the telemetry subscription QoS.
"""

from ateam_controls_analysis.routing import (
    BCM_GLOBAL_ACCEL,
    BCM_GLOBAL_POSITION,
    BCM_GLOBAL_VELOCITY,
    BCM_LOCAL_ACCEL,
    BCM_LOCAL_VELOCITY,
    compute_dimensions,
    DIMS,
    TelemetrySample,
)
from ateam_controls_analysis_msgs.msg import ControlsAnalysis
from ateam_radio_msgs.msg import ExtendedTelemetry
import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, ReliabilityPolicy


def _extract_cmd_native(bct):
    """Pull the active maneuver's echoed command as an (a, b, c) tuple.

    Returns None for modes without a direct x/y/theta command mapping.
    """
    mode = bct.body_control_mode
    if mode == BCM_GLOBAL_POSITION:
        e = bct.maneuver_global_pos.cmd_echo
        return (e.global_x, e.global_y, e.global_theta)
    if mode == BCM_GLOBAL_VELOCITY:
        e = bct.maneuver_global_vel.cmd_echo
        return (e.global_xd, e.global_yd, e.global_omega)
    if mode == BCM_LOCAL_VELOCITY:
        e = bct.maneuver_local_vel.cmd_echo
        return (e.local_xd, e.local_yd, e.local_omega)
    if mode == BCM_GLOBAL_ACCEL:
        e = bct.maneuver_global_acc.cmd_echo
        return (e.global_xdd, e.global_ydd, e.global_alpha)
    if mode == BCM_LOCAL_ACCEL:
        e = bct.maneuver_local_acc.cmd_echo
        return (e.local_xdd, e.local_ydd, e.local_alpha)
    return None


class ControlsAnalysisNode(Node):
    """Republishes one robot's ExtendedTelemetry as ControlsAnalysis."""

    def __init__(self):
        super().__init__('controls_analysis_node')

        robot_id = self.declare_parameter('robot_id', 0).value
        input_topic = self.declare_parameter('input_topic', '').value
        output_topic = self.declare_parameter('output_topic', '').value
        reliability = self.declare_parameter('reliability', 'reliable').value

        if not input_topic:
            input_topic = f'/robot_feedback/extended/robot{robot_id}'
        if not output_topic:
            output_topic = f'/controls_analysis/robot{robot_id}'

        rel = (ReliabilityPolicy.BEST_EFFORT
               if str(reliability).lower() == 'best_effort'
               else ReliabilityPolicy.RELIABLE)
        sub_qos = QoSProfile(depth=50)
        sub_qos.reliability = rel

        self._prev_mode = None
        self._pub = self.create_publisher(ControlsAnalysis, output_topic, 50)
        self._sub = self.create_subscription(
            ExtendedTelemetry, input_topic, self._on_telemetry, sub_qos)

        self.get_logger().info(
            f"controls_analysis: robot_id={robot_id} "
            f"in='{input_topic}' out='{output_topic}' "
            f'reliability={reliability}')

    def _on_telemetry(self, msg):
        bct = msg.body_control_telemetry
        sample = TelemetrySample(
            mode=bct.body_control_mode,
            kf_pos_estimate=bct.kf_body_pos_estimate,
            kf_vel_estimate=bct.kf_body_vel_estimate,
            traj_pos=bct.body_traj_pos,
            traj_vel=bct.body_traj_vel,
            vision_pose=bct.vision_pose,
            imu_gyro=bct.imu_gyro,
            imu_accel=bct.imu_accel,
            accel_u=bct.body_accel_u,
            accel_u_fric_comp=bct.body_accel_u_fric_comp,
            cmd_native=_extract_cmd_native(bct),
        )

        dims = compute_dimensions(sample, self._prev_mode)
        self._prev_mode = bct.body_control_mode

        out = ControlsAnalysis()
        out.header.stamp = self.get_clock().now().to_msg()
        out.body_control_mode = int(bct.body_control_mode)
        out.theta_estimate = float(bct.kf_body_pos_estimate[2])
        for dim in DIMS:
            sub = getattr(out, dim)
            for name, value in dims[dim].items():
                setattr(sub, name, value)

        self._pub.publish(out)


def main(args=None):
    rclpy.init(args=args)
    node = ControlsAnalysisNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.try_shutdown()


if __name__ == '__main__':
    main()
