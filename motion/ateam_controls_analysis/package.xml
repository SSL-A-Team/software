<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>ateam_controls_analysis</name>
  <version>0.0.0</version>
  <description>
    Controls analysis infrastructure for PlotJuggler. Republishes a single
    robot's ExtendedTelemetry as flat, PlotJuggler-friendly analysis signals
    (state estimate, reference trajectory, measurements, firmware output, and
    the mode-routed software command) for streaming or ROS-bag playback.
  </description>
  <maintainer email="nickwitten@users.noreply.github.com">Nick Witten</maintainer>
  <license>MIT</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>ament_cmake_python</buildtool_depend>

  <exec_depend>rclpy</exec_depend>
  <exec_depend>ateam_radio_msgs</exec_depend>
  <exec_depend>ateam_controls_analysis_msgs</exec_depend>

  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>
  <test_depend>ament_copyright</test_depend>
  <test_depend>ament_flake8</test_depend>
  <test_depend>ament_pep257</test_depend>
  <test_depend>python3-pytest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
